# Application
APP_NAME=DocMind
APP_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database
POSTGRES_USER=docmind
POSTGRES_PASSWORD=docmind_password
POSTGRES_DB=docmind_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://docmind:docmind_password@db:5432/docmind_db

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/docmind_uploads
